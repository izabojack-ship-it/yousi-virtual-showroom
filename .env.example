# === 開發環境 ===
DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1
LANGUAGE_CODE=zh-hant
TIME_ZONE=Asia/Taipei
RUN_PORT=9000

# === 資料庫（開發用 sqlite，正式環境改 postgresql）===
DB_ENGINE=sqlite
# DB_ENGINE=postgresql
# DB_NAME=yousi_showroom
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432
# PaaS（Render/Railway）會提供單一連線字串，設定後優先採用：
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# === 圖片 CDN（Cloudinary，選填）===
# 設定後，後台上傳的所有圖片會自動存到 Cloudinary 並由全球 CDN 交付。
# 未設定時自動退回本機 media/ 儲存。
# 金鑰格式（在 Cloudinary Dashboard 首頁可複製）：
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# === 展間照片 AI 去雜物（選填）===
# 設定 REPLICATE_API_TOKEN 可啟用 SDXL 自動去除電風扇、垃圾袋、走道雜物
# REPLICATE_API_TOKEN=
# REPLICATE_MODEL=stability-ai/sdxl:39ed52f2a78e934b3ba6e2a89fbf45c17c114af5ee346f735020d8df092ed784
# IMAGE_PROCESSOR_URL=http://127.0.0.1:4100
# IMAGE_PROCESSOR_PROVIDER=replicate
# SHOWROOM_PUBLIC_BASE_URL=http://127.0.0.1:9000

# === 公開預覽 / 正式部署 ===
# ALLOWED_HOSTS=your-domain.com,.trycloudflare.com
# CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://xxx.trycloudflare.com
# BEHIND_PROXY=True
# SERVE_MEDIA=True
# SHOWROOM_PUBLIC_BASE_URL=https://your-domain.com

# PREVIEW_MODE=True
# PREVIEW_PASSWORD=your-preview-passcode

# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=True
# CORS_ALLOWED_ORIGINS=https://showroom.yousi.com.tw
